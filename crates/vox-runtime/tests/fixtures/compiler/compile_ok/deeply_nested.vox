script fixtures.compile.deeply_nested;

param depth: Int = 3;

fun deeplyNestedIf(n: Int): Int {
    if (n > 0) {
        if (n > 1) {
            if (n > 2) {
                if (n > 3) {
                    if (n > 4) {
                        if (n > 5) {
                            return 6;
                        };
                        return 5;
                    };
                    return 4;
                };
                return 3;
            };
            return 2;
        };
        return 1;
    };
    0
}

fun deeplyNestedFor(limit: Int): Int {
    var result: Int = 0;
    var i: Int = 0;
    for (i < limit) {
        var j: Int = 0;
        for (j < limit) {
            var k: Int = 0;
            for (k < limit) {
                result += 1;
                k += 1;
            };
            j += 1;
        };
        i += 1;
    };
    result
}

val dnf = deeplyNestedIf(4);
val dnloop = deeplyNestedFor(3);

dnf

