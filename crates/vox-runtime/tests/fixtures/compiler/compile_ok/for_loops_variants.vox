script fixtures.compile.for_loops;

param limit: Int = 10;

fun allLoops(limit: Int): Int {
    var count: Int = 0;

    for (var j: Int = 0; j in 0..limit) {
        count += 1;
        if (j > 3) {
            continue;
        }
        count += 1;
    }

    for (count < 20) {
        count += 1;
    }

    for (val i: Int = 0; i < limit) {
        count += 1;
        if (count > 15) {
            break;
        }
    }

    count
}

allLoops(0)

