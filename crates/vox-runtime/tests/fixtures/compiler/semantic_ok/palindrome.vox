script fixtures.algorithm.palindrome;

fun reverse(str: String): String {
    var result: String = "";
    var i: Int = str.length() - 1;
    for (i >= 0) {
        val ch = str.substring(i, i + 1);
        result = result + ch;
        i -= 1;
    };
    result
}

fun isPalindrome(str: String): Bool {
    str == reverse(str)
}

fun isPalindromeFast(str: String): Bool {
    var left: Int = 0;
    var right: Int = str.length() - 1;
    for (left < right) {
        if (str.substring(left, left + 1) != str.substring(right, right + 1)) {
            return false;
        };
        left += 1;
        right -= 1;
    };
    true
}

val p1: Bool = isPalindrome("racecar");
val p2: Bool = isPalindrome("hello");
val p3: Bool = isPalindromeFast("abba");
val p4: Bool = isPalindromeFast("abc");

p1

