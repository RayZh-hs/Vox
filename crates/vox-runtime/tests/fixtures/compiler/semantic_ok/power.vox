script fixtures.algorithm.power;

fun power(base: Int, exp: Int): Int {
    (if (exp == 0) {
        1
    } else {
        (if (exp % 2 == 0) {
            val half = power(base, exp / 2);
            half * half
        } else {
            base * power(base, exp - 1)
        })
    })
}

val pow2_10 = power(2, 10);
val pow3_5 = power(3, 5);
val pow5_3 = power(5, 3);
val pow7_0 = power(7, 0);

pow2_10

