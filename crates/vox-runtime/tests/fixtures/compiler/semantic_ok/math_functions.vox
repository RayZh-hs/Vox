script fixtures.semantic.math_functions;

fun abs(n: Int): Int {
    (if (n < 0) { -n } else { n })
}

fun min(a: Int, b: Int): Int {
    (if (a < b) { a } else { b })
}

fun max(a: Int, b: Int): Int {
    (if (a > b) { a } else { b })
}

fun clamp(v: Int, lo: Int, hi: Int): Int {
    max(lo, min(v, hi))
}

fun isDivisibleBy(a: Int, b: Int): Bool {
    b != 0 && a % b == 0
}

fun triangle(n: Int): Int {
    n * (n + 1) / 2
}

val absNeg = abs(-42);
val minVal = min(10, -5);
val maxVal = max(10, -5);
val clamped = clamp(15, 0, 10);
val tri10 = triangle(10);

absNeg

