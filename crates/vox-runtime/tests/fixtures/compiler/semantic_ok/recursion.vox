script fixtures.semantic.recursion;

fun factorial(n: Int): Int {
    (if (n <= 1) {
        1
    } else {
        n * factorial(n - 1)
    })
}

fun fibonacci(n: Int): Int {
    (if (n <= 1) {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    })
}

val fact5: Int = factorial(5);
val fib5: Int = fibonacci(5);

fact5

